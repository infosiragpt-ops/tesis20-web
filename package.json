{
  "name": "tesis20-local",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:lan": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build && node scripts/generate-static-routes.mjs",
    "preview": "vite preview --port 3000",
    "audio:nido": "node scripts/generate-nido-openrouter-audio.mjs",
    "audio:nido:legacy-elevenlabs": "node scripts/generate-nido-elevenlabs-audio.mjs",
    "quality": "node scripts/quality-check.mjs",
    "check:nido": "node scripts/check-nido-curriculum.mjs",
    "check": "npm run build && npm run quality && npm run check:nido"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.3"
  }
}
