# Se usa solo en un entorno seguro de generación local o CI; la web publicada
# no necesita esta clave. Nunca use un nombre VITE_*: esas variables se
# incrustan en el JavaScript público.
OPENROUTER_API_KEY=

# Opcionales. Los valores por defecto están optimizados para una maestra
# profesional de educación inicial en español latino.
OPENROUTER_TTS_MODEL=x-ai/grok-voice-tts-1.0
OPENROUTER_TTS_VOICE=ara
